# Phase 2 controlled real-testing example
# Copy this to .env locally and replace values with real secrets only on your machine.
# Never commit real credentials.

# Slack app credentials
SLACK_SIGNING_SECRET=mock_slack_signing_secret_replace_locally
SLACK_BOT_TOKEN=xoxb-mock-token-replace-locally

# Slack testing defaults
SLACK_TEST_TEAM_ID=T_DEMO
SLACK_TEST_MAPPED_CHANNEL_ID=C_ACME
SLACK_TEST_UNMAPPED_CHANNEL_ID=C_UNMAPPED
SLACK_TEST_USER_ID=U_DEMO

# Durable background jobs (postgres) or local in-process only (in-memory)
QUEUE_ADAPTER=postgres

# LiteLLM proxy
LITELLM_PROXY_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-mock-litellm-master-key-replace-locally
LITELLM_DEFAULT_MODEL=gpt-4o-mini
LITELLM_REQUEST_TIMEOUT_MS=30000

# Provider keys belong in LiteLLM config/env only, not app code.
# Example only — do not commit real provider keys.
OPENAI_API_KEY=sk-mock-openai-key-replace-locally
ANTHROPIC_API_KEY=sk-ant-mock-anthropic-key-replace-locally

# Optional future analytics connection to LiteLLM DB
# Use read-only credentials in real environments.
LITELLM_ANALYTICS_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/litellm
