generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AgencyPlan {
  STARTER
  GROWTH
  ENTERPRISE
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum ClientStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowStatus {
  DRAFT
  LIVE
  PAUSED
}

enum UsageSource {
  WEB
  API
  WORKFLOW
  SLACK
}

enum CurrencyCode {
  USD
}

model Agency {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  plan            AgencyPlan         @default(STARTER)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  memberships     AgencyMembership[]
  clients         Client[]
  projects        Project[]
  workflows       Workflow[]
  slackWorkspaces SlackWorkspace[]
  slackChannels   SlackChannel[]
  usageEvents     UsageEvent[]
}

model User {
  id          String             @id @default(cuid())
  email       String             @unique
  name        String?
  imageUrl    String?
  timezone    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  memberships AgencyMembership[]
  usageEvents UsageEvent[]
}

model AgencyMembership {
  id        String         @id @default(cuid())
  agencyId  String
  userId    String
  role      MembershipRole @default(MEMBER)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  agency    Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([agencyId, userId])
  @@index([userId])
}

model Client {
  id              String        @id @default(cuid())
  agencyId        String
  name            String
  slug            String
  status          ClientStatus  @default(ACTIVE)
  billingCurrency CurrencyCode  @default(USD)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  agency          Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  projects        Project[]
  usageEvents     UsageEvent[]

  @@unique([agencyId, slug])
  @@index([agencyId, status])
}

model Project {
  id             String         @id @default(cuid())
  agencyId       String
  clientId       String
  name           String
  slug           String
  description    String?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  agency         Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workflows      Workflow[]
  slackChannels  SlackChannel[]
  usageEvents    UsageEvent[]

  @@unique([agencyId, slug])
  @@index([clientId, isActive])
}

model Workflow {
  id            String         @id @default(cuid())
  agencyId      String
  projectId     String
  name          String
  slug          String
  provider      String?
  model         String?
  status        WorkflowStatus @default(DRAFT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  agency        Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  slackChannels SlackChannel[]
  usageEvents   UsageEvent[]

  @@unique([agencyId, slug])
  @@index([projectId, status])
}

model SlackWorkspace {
  id          String         @id @default(cuid())
  agencyId    String
  teamId      String         @unique
  name        String
  domain      String?
  installedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  agency      Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  channels    SlackChannel[]

  @@index([agencyId])
}

model SlackChannel {
  id               String         @id @default(cuid())
  agencyId         String
  workspaceId      String
  projectId        String?
  workflowId       String?
  slackChannelId   String
  name             String
  isArchived       Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  agency           Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  workspace        SlackWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project          Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workflow         Workflow?      @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  usageEvents      UsageEvent[]

  @@unique([workspaceId, slackChannelId])
  @@index([agencyId, isArchived])
  @@index([projectId])
  @@index([workflowId])
}

model UsageEvent {
  id               String        @id @default(cuid())
  agencyId         String
  clientId         String?
  projectId        String?
  workflowId       String?
  userId           String?
  slackChannelId   String?
  requestId        String?       @unique
  source           UsageSource
  provider         String
  model            String
  promptTokens     Int           @default(0)
  completionTokens Int           @default(0)
  cacheReadTokens  Int           @default(0)
  cacheWriteTokens Int           @default(0)
  totalTokens      Int           @default(0)
  inputCost        Decimal       @db.Decimal(18, 6)
  outputCost       Decimal       @db.Decimal(18, 6)
  totalCost        Decimal       @db.Decimal(18, 6)
  currency         CurrencyCode  @default(USD)
  occurredAt       DateTime
  metadata         Json?
  createdAt        DateTime      @default(now())
  agency           Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client           Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project          Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workflow         Workflow?     @relation(fields: [workflowId], references: [id], onDelete: SetNull)
  user             User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  slackChannel     SlackChannel? @relation(fields: [slackChannelId], references: [id], onDelete: SetNull)

  @@index([agencyId, occurredAt])
  @@index([clientId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([workflowId, occurredAt])
  @@index([userId, occurredAt])
  @@index([slackChannelId, occurredAt])
}
