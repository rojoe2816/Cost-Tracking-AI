generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum ClientStatus {
  ACTIVE
  ARCHIVED
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

enum PromptStorageMode {
  METADATA_ONLY
  REDACTED
  FULL_LOGGING
}

enum AiRequestSource {
  SLACK
  WEB
}

enum AiRequestStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model Organization {
  id                   String                       @id @default(cuid())
  name                 String
  slug                 String                       @unique
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  memberships          Membership[]
  clients              Client[]
  projects             Project[]
  workflowTypes        WorkflowType[]
  slackWorkspaces      SlackWorkspace[]
  slackChannelMappings SlackChannelMapping[]
  clientRevenues       ClientRevenue[]
  privacySettings      OrganizationPrivacySettings?
  aiRequestAudits      AiRequestAudit[]

  @@index([createdAt])
}

model AppUser {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  memberships     Membership[]
  aiRequestAudits AiRequestAudit[]

  @@index([createdAt])
}

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole @default(MEMBER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           AppUser        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([createdAt])
}

model Client {
  id                   String                @id @default(cuid())
  organizationId       String
  name                 String
  externalAccountingId String?
  status               ClientStatus          @default(ACTIVE)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projects             Project[]
  slackChannelMappings SlackChannelMapping[]
  clientRevenues       ClientRevenue[]
  aiRequestAudits      AiRequestAudit[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

model Project {
  id                   String                @id @default(cuid())
  organizationId       String
  clientId             String
  name                 String
  status               ProjectStatus         @default(ACTIVE)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client               Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  slackChannelMappings SlackChannelMapping[]
  clientRevenues       ClientRevenue[]
  aiRequestAudits      AiRequestAudit[]

  @@unique([organizationId, clientId, name])
  @@index([organizationId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

model WorkflowType {
  id                   String                @id @default(cuid())
  organizationId       String
  name                 String
  slug                 String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slackChannelMappings SlackChannelMapping[]
  aiRequestAudits      AiRequestAudit[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([createdAt])
}

model SlackWorkspace {
  id              String                @id @default(cuid())
  organizationId  String
  slackTeamId     String                @unique
  slackTeamName   String?
  botUserId       String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channelMappings SlackChannelMapping[]

  @@index([organizationId])
  @@index([createdAt])
}

model SlackChannelMapping {
  id                    String         @id @default(cuid())
  organizationId        String
  slackWorkspaceId      String
  slackChannelId        String
  slackChannelName      String?
  clientId              String?
  projectId             String?
  defaultWorkflowTypeId String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slackWorkspace        SlackWorkspace @relation(fields: [slackWorkspaceId], references: [id], onDelete: Cascade)
  client                Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project               Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  defaultWorkflowType   WorkflowType?  @relation(fields: [defaultWorkflowTypeId], references: [id], onDelete: SetNull)

  @@unique([slackWorkspaceId, slackChannelId])
  @@index([organizationId])
  @@index([clientId])
  @@index([projectId])
  @@index([createdAt])
}

model ClientRevenue {
  id                    String       @id @default(cuid())
  organizationId        String
  clientId              String
  projectId             String?
  month                 String
  revenueUsd            Decimal      @db.Decimal(18, 2)
  estimatedLaborCostUsd Decimal?     @db.Decimal(18, 2)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project               Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([clientId, projectId, month])
  @@index([organizationId])
  @@index([clientId])
  @@index([projectId])
  @@index([month])
  @@index([createdAt])
}

model OrganizationPrivacySettings {
  id                String            @id @default(cuid())
  organizationId    String            @unique
  promptStorageMode PromptStorageMode @default(METADATA_ONLY)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model AiRequestAudit {
  id                       String          @id @default(cuid())
  organizationId           String
  userId                   String?
  source                   AiRequestSource
  status                   AiRequestStatus
  externalLiteLlmRequestId String?
  slackTeamId              String?
  slackChannelId           String?
  slackThreadTs            String?
  slackMessageTs           String?
  clientId                 String?
  projectId                String?
  workflowTypeId           String?
  promptStored             Boolean         @default(false)
  errorMessage             String?
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  organization             Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                     AppUser?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  client                   Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project                  Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  workflowType             WorkflowType?   @relation(fields: [workflowTypeId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([clientId])
  @@index([projectId])
  @@index([workflowTypeId])
  @@index([status])
  @@index([createdAt])
  @@index([externalLiteLlmRequestId])
  @@index([slackTeamId, slackChannelId])
}
